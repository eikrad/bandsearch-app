PORT=3001
GEMINI_API_KEY=your_gemini_api_key_here

# Storage: sqlite (default, no setup needed), memory (no persistence), postgres
# PREFERENCE_STORE=sqlite
# DATABASE_PATH=bandsearch.db

# Postgres (only needed when PREFERENCE_STORE=postgres)
# DATABASE_URL=postgresql://user:pass@localhost:5432/bandsearch
# DATABASE_SSL=false

# LangSmith tracing (optional)
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=bandsearch-dev

CORS_ORIGIN=http://localhost:1420
RECOMMENDATION_TIMEOUT_MS=8000
MUSICBRAINZ_TIMEOUT_MS=5000
MUSICBRAINZ_RETRIES=1
