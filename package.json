{
  "name": "bandsearch",
  "version": "0.2.0-alpha.1",
  "private": true,
  "description": "Bandsearch monorepo foundation",
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "shared/*"
  ],
  "scripts": {
    "start": "node services/api/src/server.js",
    "dev": "node services/api/src/server.js",
    "desktop": "npm run tauri:dev --workspace @bandsearch/desktop",
    "migrate": "npm run migrate --workspace @bandsearch/api",
    "lint:js": "npm run lint --workspaces --if-present",
    "lint:py": "ruff check . && black --check .",
    "lint": "npm run lint:js && npm run lint:py",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "ci": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "eslint": "^9.26.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.3"
  }
}
