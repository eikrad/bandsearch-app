{
  "name": "bandsearch",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "bandsearch",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "workspaces": [
        "apps/*",
        "services/*",
        "shared/*"
      ]
    },
    "apps/desktop": {
      "name": "@bandsearch/desktop",
      "version": "0.1.0"
    },
    "node_modules/@bandsearch/api": {
      "resolved": "services/api",
      "link": true
    },
    "node_modules/@bandsearch/desktop": {
      "resolved": "apps/desktop",
      "link": true
    },
    "node_modules/@bandsearch/schemas": {
      "resolved": "shared/schemas",
      "link": true
    },
    "services/api": {
      "name": "@bandsearch/api",
      "version": "0.1.0"
    },
    "shared/schemas": {
      "name": "@bandsearch/schemas",
      "version": "0.1.0"
    }
  }
}
